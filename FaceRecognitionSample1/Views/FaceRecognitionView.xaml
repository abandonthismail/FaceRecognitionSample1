<UserControl x:Class="FaceRecognitionSample1.Views.FaceRecognitionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FaceRecognitionSample1.ViewModels"
        xmlns:views="clr-namespace:FaceRecognitionSample1.Views"
        xmlns:converters="clr-namespace:FaceRecognitionSample1.Converters"
        xmlns:helpers="clr-namespace:FaceRecognitionSample1.Helpers"
        xmlns:properties="clr-namespace:FaceRecognitionSample1.Properties"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        d:DesignWidth="1200" d:DesignHeight="800">

    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <DataTemplate DataType="{x:Type vm:OneToOneViewModel}">
            <views:OneToOneResultView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OneToManyViewModel}">
            <views:OneToManyResultView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="450" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Border Width="300" Height="400" Background="#111" CornerRadius="6" ClipToBounds="True">
                <Image Source="{Binding CameraFrame}" Stretch="Uniform"/>
            </Border>

        </Viewbox>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ContentControl Grid.Row="0" Content="{Binding CurrentResultViewModel}" VerticalAlignment="Stretch" Margin="0,0,0,15"/>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--
                <GroupBox Grid.Column="0" Grid.Row="0" Header="{x:Static properties:Resources.MetricsTitle}" Margin="0,0,10,0" Height="280">
                    <ListView ItemsSource="{Binding Metrics}" BorderThickness="0" Background="Transparent" Margin="2">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Margin" Value="0,2,0,2"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="GridViewColumnHeader">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Width="105">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="Gray" FontWeight="SemiBold" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
                -->
                <GroupBox Grid.Column="0" Grid.Row="0" Header="{x:Static properties:Resources.MetricsTitle}" Margin="0,0,10,0" Height="280">
                    <ItemsControl ItemsSource="{Binding VisibleMetrics}" Margin="12,15,12,12">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="65" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="Gray" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </GroupBox>

                <Button Grid.Column="0" Grid.Row="1" 
                        Command="{Binding OpenSettingsCommand}" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,15,10,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Border BorderBrush="#0052CC" BorderThickness="1" CornerRadius="4" Padding="0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⚙" Foreground="#0052CC" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static properties:Resources.BtnSettings}" Foreground="#0052CC" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Button>


                <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                    <GroupBox Header="{x:Static properties:Resources.HeaderRecognitionMode}">
                        <StackPanel Orientation="Horizontal" Margin="8">
                            <RadioButton Content="{x:Static properties:Resources.ModeOneToOne}"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=OneToOne}" 
                                         Margin="0,0,25,0"/>
                            <RadioButton Content="{x:Static properties:Resources.ModeOneToMany}"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=OneToMany}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{x:Static properties:Resources.HeaderTriggerMode}" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="8">
                            <RadioButton Content="{x:Static properties:Resources.TriggerManual}" 
                                         IsChecked="{Binding SelectedRecognitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Trigger}" 
                                         Margin="0,0,25,0"/>
                            <RadioButton Content="{x:Static properties:Resources.TriggerRealtime}"
                                         IsChecked="{Binding SelectedRecognitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=RealTime}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{x:Static properties:Resources.HeaderTargetUser}" Margin="0,10,0,0">
                        <StackPanel Margin="5">
                            <Border CornerRadius="5" BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Margin="0,0,0,6"
                                    IsEnabled="{Binding SelectedMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=OneToOne}">
                                <Grid>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Height="26" VerticalContentAlignment="Center" Padding="5,0,25,0"/>
                                    <TextBlock Text="{x:Static properties:Resources.PlaceholderSearchUser}" Foreground="LightGray" IsHitTestVisible="False" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="🔍" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Gray"/>
                                </Grid>
                            </Border>

                            <Border CornerRadius="5" BorderBrush="#CCCCCC" BorderThickness="1" Background="White" ClipToBounds="True"
                                    IsEnabled="{Binding SelectedMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=OneToOne}">
                                <ComboBox BorderThickness="0" Background="Transparent" Height="26" SelectedIndex="0">
                                    <ComboBoxItem Content="{x:Static properties:Resources.ComboDefaultSelectUser}"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="{x:Static properties:Resources.StartRecognition}" Height="40" Margin="0,15,0,0" 
                            Background="#0052CC" Foreground="White" FontSize="15" FontWeight="Bold" BorderThickness="0"
                            IsEnabled="{Binding SelectedRecognitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Trigger}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <Button Grid.Column="1" Grid.Row="1" 
                        Command="{Binding OpenUserManagementCommand}" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="10,15,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Border BorderBrush="#0052CC" BorderThickness="1" CornerRadius="4" Padding="0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="👤" Foreground="#0052CC" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static properties:Resources.BtnUserManagement}" Foreground="#0052CC" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Button>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
