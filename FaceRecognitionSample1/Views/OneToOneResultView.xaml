<UserControl x:Class="FaceRecognitionSample1.Views.OneToOneResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.expression/blend/2008" 
             xmlns:p="clr-namespace:FaceRecognitionSample1.Properties"
             xmlns:properties="clr-namespace:FaceRecognitionSample1.Properties"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Static p:Resources.ResultTitleOneToOne}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <TextBlock Text="{x:Static p:Resources.QueryImage}" HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="Gray"/>
                <Border Width="110" Height="110" Background="#F0F2F5" CornerRadius="6" BorderBrush="LightGray" BorderThickness="1">
                    <Image Source="{Binding QueryImage}" Stretch="UniformToFill"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="{x:Static p:Resources.TargetImage}" HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="Gray"/>
                <Border Width="110" Height="110" Background="#F0F2F5" CornerRadius="6" BorderBrush="LightGray" BorderThickness="1">
                    <Image Source="{Binding TargetImage}" Stretch="UniformToFill"/>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="8" Padding="10" VerticalAlignment="Top" Margin="5,22,5,0">
                <StackPanel Grid.Column="2" HorizontalAlignment="Stretch">
                    <TextBlock Text="{x:Static p:Resources.ScoreLabel}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Score, TargetNullValue='-', StringFormat=\{0:F4\}}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,12"/>

                    <Border Height="1" Background="#E0E0E0" Margin="0,0,0,10"/>

                    <TextBlock Text="{x:Static p:Resources.JudgmentLabel}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtJudgment" Text="-" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMatch}" Value="True">
                                        <Setter Property="Foreground" Value="#28A745"/>
                                        <Setter Property="Text" Value="{x:Static p:Resources.StatusMatch}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                        <Setter Property="Foreground" Value="#DC3545"/>
                                        <Setter Property="Text" Value="{x:Static p:Resources.StatusMismatch}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>